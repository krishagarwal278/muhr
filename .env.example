# =============================================================================
# Muhr Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# Get these from your Supabase project settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - NEVER expose to client, server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Resend (Email)
# Get this from your Resend dashboard
# -----------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
# Default transactional sender (must be verified in Resend)
RESEND_FROM_EMAIL=Muhr <contact@muhr.app>
# Internal notifications and user-facing support contact
SUPPORT_EMAIL=contact@muhr.app

# -----------------------------------------------------------------------------
# fal.ai (Image Generation)
# Get this from your fal.ai dashboard
# -----------------------------------------------------------------------------
FAL_KEY=your-fal-key

# -----------------------------------------------------------------------------
# Brand Preview (Optional)
# Comma-separated list of email addresses allowed to access brand workspace
# Leave empty to disable brand preview
# -----------------------------------------------------------------------------
BRAND_PREVIEW_EMAILS=

# -----------------------------------------------------------------------------
# Internal ops (server-only)
# Protects GET /api/internal/character-photos/audit
# -----------------------------------------------------------------------------
ADMIN_AUDIT_SECRET=

# -----------------------------------------------------------------------------
# Razorpay (Payments)
# Test keys from https://dashboard.razorpay.com/app/keys
# NEXT_PUBLIC_RAZORPAY_KEY_ID is safe to expose (public key id only)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-test-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
# Set after configuring webhook in Razorpay dashboard (Phase 5)
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Development Only (DO NOT SET IN PRODUCTION)
# -----------------------------------------------------------------------------
