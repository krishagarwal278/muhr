## Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias for the same anon **public** key (not service_role); `lib/supabase/client.ts` falls back if NEXT_PUBLIC_* is unset in your environment.
# SUPABASE_ANON_KEY=
## Use your public site (e.g. https://muhr.app) so /k/:handle links and QR codes show production URLs even in local dev.
NEXT_PUBLIC_APP_URL=https://muhr.app
NEXT_PUBLIC_PERSONA_TEMPLATE_ID=
NEXT_PUBLIC_PERSONA_ENVIRONMENT_ID=

## Server-only secrets (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
RESEND_API_KEY=

## Server config / defaults
RESEND_FROM_EMAIL=
## Optional: where to receive new public license-request notifications (defaults to founder inbox in code).
LICENSE_REQUEST_NOTIFY_EMAIL=
SUPPORT_EMAIL=
MUHR_FACE_EMBEDDING_URL=

## Local dev only (do not set in production)
# When set to 1 in development only, middleware skips session checks (never active in production builds).
DEV_AUTH_BYPASS=

## Brand workspace (preview; optional)
# Email of a Supabase Auth user you create manually for designers/PMs. Login page pre-fills this when
# `next` is under `/brand` or `intent=brand`. Password is never stored in the app — set it in Supabase.
NEXT_PUBLIC_BRAND_PREVIEW_SIGNIN_EMAIL=

## Rate limiting
# Per-route limits use an in-memory sliding window (per server instance). For strict global limits in
# multi-instance production, add an external store (e.g. Upstash Redis) and wire `lib/ratelimit.ts`.
